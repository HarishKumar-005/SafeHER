# =====================================================
# SafeHer AR — Android .gitignore
# Judges see: source code, docs, README, resources
# =====================================================

# ─── BUILD OUTPUTS ────────────────────────────────
*.apk
*.ap_
*.aab
*.dex
*.class
bin/
gen/
out/
build/
.gradle/
app/build/
*/build/

# ─── LOCAL / SECRET FILES ─────────────────────────
# SDK path & API keys — never commit
local.properties

# Keystore files — NEVER commit signing keys
*.jks
*.keystore
*.pem
*.p12
*.key
release-key.jks
debug.keystore

# Google Services — judges should use their own Firebase project
# (see work/docs/firebase-swap-instructions.md)
google-services.json

# ─── IDE / EDITOR SETTINGS ────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.classpath
.project
.settings/
nbproject/private/
*.suo
*.user

# ─── ANDROID STUDIO SPECIFIC ──────────────────────
.navigation/
captures/
.cxx/
*.cxx/
.externalNativeBuild/

# ─── RAW / STAGING ASSET FOLDERS ──────────────────
# These are the original icon export folders — the final icons
# are already in the correct res/mipmap-* folders
app/src/main/AppIcons/
app/src/main/res/AppIcons/

# ─── AGENT WORK ARTIFACTS (internal only) ─────────
# These are refactor logs, workspace scans, and internal docs
# produced by the AI agent — not relevant to judges.
work/logs/
work/memory/
work/artifacts/
work/reports/
# Keep work/docs/ — it has firebase & deployment guides judges may read

# ─── WEB PROTOTYPE FILES ──────────────────────────
# These were part of an early prototype, not the Android app
index.html
script.js
styles.css

# ─── OS JUNK ──────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.directory

# ─── TEMP / CRASH / PROFILE FILES ─────────────────
*.log
*.hprof
hs_err_pid*
replay_pid*
.mtj.tmp/
firebase-debug.log
firestore-debug.log
ui-debug.log
.firebase/

# ─── RAW JSON SCAN FILES (agent-generated) ────────
work/docs/raw_scan.json
work/docs/workspace-analysis.json

# ─── ARCHIVES ─────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z
# Allow the release package if present
!work/release/*.zip
